# Vendor-neutral compose stack — environment. Copy to `.env`, fill secrets, then
#   docker compose up --build
# These values feed docker-compose.yml variable substitution. (The backend's own
# full env surface is documented in ../../backend/typescript/.env.example.)

# ── Required secrets — generate, do not reuse the placeholders ────────────────
# openssl rand -base64 32
OPENWOP_SESSION_SECRET=
# openssl rand -base64 32   (local-AES BYOK master key — wraps stored secrets)
OPENWOP_BYOK_ENCRYPTION_KEY=
# Postgres password for the bundled db service. It is embedded into the
# postgres:// DSN, so it MUST be URL-safe — generate a hex value (no +, /, @, :):
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# ── Database (defaults are fine for the bundled Postgres) ─────────────────────
POSTGRES_USER=openwop
POSTGRES_DB=openwop

# ── Runtime knobs ─────────────────────────────────────────────────────────────
# cookie-per-visitor (default) | bearer-shared | auth (needs OIDC + persistent KMS)
OPENWOP_DEPLOY_POSTURE=cookie-per-visitor
OPENWOP_SURFACE_BACKEND=durable
# Set true when serving over https (recommended in production behind TLS).
OPENWOP_COOKIE_SECURE=false
OPENWOP_LOG_LEVEL=info
# Admin token for cleanup/tenant ops (blank disables admin routes).
OPENWOP_ADMIN_TOKEN=
# Host port the nginx edge listens on (browser → http://localhost:${WEB_PORT}).
WEB_PORT=8080

# ── Branding (optional; defaults render the OpenWOP reference brand) ──────────
VITE_BRAND_PRODUCT_NAME=

# ── Sign-in via OIDC (optional; blank = anon cookie mode) ─────────────────────
# Any OIDC issuer. Examples in ../../backend/typescript/.env.example.
OPENWOP_OIDC_ISSUER=
OPENWOP_OIDC_AUDIENCE=
OPENWOP_OIDC_JWKS_URL=

# ── Object storage (only with `--profile blob`; MinIO is bundled) ─────────────
# OPENWOP_SURFACE_BLOB=s3
# OPENWOP_BLOB_S3_BUCKET=openwop
# OPENWOP_BLOB_S3_ENDPOINT=http://minio:9000
# OPENWOP_BLOB_S3_ACCESS_KEY_ID=minioadmin
# OPENWOP_BLOB_S3_SECRET_ACCESS_KEY=minioadmin
# OPENWOP_BLOB_S3_FORCE_PATH_STYLE=true
