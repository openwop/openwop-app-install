{
  "id": "conformance-identity",
  "name": "Conformance: Identity",
  "version": "1.0",
  "description": "Echoes input.payload to output.payload. Verifies input/output passthrough.",
  "nodes": [
    {
      "id": "echo",
      "typeId": "core.identity",
      "name": "Echo",
      "position": { "x": 0, "y": 0 },
      "config": {},
      "inputs": {
        "payload": { "type": "variable", "variableName": "payload" }
      }
    }
  ],
  "edges": [],
