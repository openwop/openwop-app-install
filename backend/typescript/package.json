{
  "name": "@openwop/app-server",
  "version": "0.1.0",
  "private": true,
  "description": "OpenWOP application backend — Cloud Run TypeScript host implementing the v1.1 wire contract.",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=.env lib/index.js",
    "build": "rm -rf lib && esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=lib/index.js --packages=external --sourcemap --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "build:tsc": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "check:test-ports": "node scripts/check-test-ports.mjs",
    "pretest": "node scripts/check-test-ports.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "tsx conformance/run.ts",
    "eval:workflow-author": "node scripts/eval-workflow-author.mjs",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@openwop/openwop": "^1.2.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.5.0",
    "express": "^4.21.0",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.2.0",
    "officeparser": "^7.2.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "tar-stream": "^3.1.7",
    "undici": "^7.28.0",
    "unpdf": "^1.6.2",
    "web-push": "^3.6.7"
  },
  "optionalDependencies": {
    "@aws-sdk/client-kms": "^3.700.0",
    "@azure/identity": "^4.5.0",
    "@azure/keyvault-keys": "^4.9.0",
    "@google-cloud/kms": "^5.5.0"
  },
  "devDependencies": {
    "@openwop/openwop-conformance": "^1.46.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/tar-stream": "^3.1.4",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.28.1",
    "pg-mem": "^3.0.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "vitest": "^4.1.0",
    "esbuild": "^0.28.1"
  }
}
