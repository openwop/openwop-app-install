# =============================================================================
# OpenWOP demo-app backend — example environment
# =============================================================================
# Copy to `.env` and edit. `.env` is gitignored and is NEVER shipped in the
# white-label zip (scripts/build-whitelabel-zip.sh strips every .env*), so this
# `.env.example` is the documented inventory of the knobs an adopter sets.
#
# The backend reads ~90 OPENWOP_* variables in total; the ones below are the
# install-relevant subset. Everything omitted has a safe built-in default — see
# backend/typescript/src/index.ts and src/middleware/ for the full set. Every
# var here is shown with its built-in default; uncomment + change what you need.
#
# This file is organized by CAPABILITY, not by cloud — the app is host-neutral.
# Each deploy pack under deploy/<host>/ maps these same knobs onto its platform's
# primitives (container runtime → $PORT, store → OPENWOP_STORAGE_DSN, secret wrap
# → OPENWOP_BYOK_*, identity → OPENWOP_OIDC_*, blob → OPENWOP_BLOB_S3_*). Start at
# deploy/README.md to pick a host.
#
# Companion: frontend/react/.env.production.example (the build-time VITE_* vars).
# -----------------------------------------------------------------------------

# --- Runtime posture --------------------------------------------------------
# Set this to `production` for any real deploy. It hardens cookie flags and is
# what the session-secret guard (below) keys on. Leaving it unset runs the
# backend in a DEMO posture (ephemeral secret, insecure cookies) — fine for
# local dev, NOT for a deployment.
# NODE_ENV=production

# TCP port the HTTP server binds. (default: 8080)
# PORT=8080

# --- Identity (advertised at /.well-known/openwop) --------------------------
# OPENWOP_SERVICE_NAME=openwop-workflow-engine
# OPENWOP_SERVICE_VERSION=0.1.0
# OPENWOP_SERVICE_VENDOR=
# OPENWOP_SERVICE_DESCRIPTION=

# --- Storage ----------------------------------------------------------------
# Event log + suspend store DSN. Defaults to a local SQLite file (created on
# first run). Point at Postgres for a durable multi-instance deploy — ANY
# Postgres works (RDS, Azure Database for PostgreSQL, Cloud SQL, Neon, Supabase,
# self-hosted, the compose `db`), e.g.
#   postgres://user:pass@host:5432/openwop
# Cloud SQL Unix-socket form: postgresql://u:p@/openwop?host=/cloudsql/<conn>
# (default: sqlite://./data/workflow-engine.db)
# OPENWOP_STORAGE_DSN=sqlite://./data/workflow-engine.db

# --- Auth / session (P0.2) --------------------------------------------------
# REQUIRED in production for cookie-mode auth. Min 32 chars. With NODE_ENV=
# production unset OR this unset, the backend mints cookies with an EPHEMERAL
# per-process secret (sessions break on every restart). With NODE_ENV=production
# set, a missing/short secret is a HARD startup error — generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OPENWOP_SESSION_SECRET=

# Auth posture. One of: bearer-shared | cookie-per-visitor | auth.
#   cookie-per-visitor — anon per-visitor tenants, in-memory secrets (no DB/KMS).
#   bearer-shared      — a single shared OPENWOP_API_KEYS / OPENWOP_ADMIN_TOKEN.
#   auth               — signed-in (OIDC) tenants with persistent, KMS-wrapped
#                        secrets. REQUIRES OPENWOP_STORAGE_DSN + a real
#                        OPENWOP_BYOK_KMS_KEY (server refuses to boot otherwise).
# (default: cookie-per-visitor, or `auth` when OPENWOP_AUTH_ENFORCE_BEARER=true)
# OPENWOP_DEPLOY_POSTURE=cookie-per-visitor

# Session cookie name. (default: __session)
# OPENWOP_SESSION_COOKIE_NAME=__session

# Force the Secure flag on session cookies. Auto-on when NODE_ENV=production.
# OPENWOP_COOKIE_SECURE=true

# Admin endpoints (cleanup, tenant ops). Blank disables admin routes.
# OPENWOP_ADMIN_TOKEN=

# Bearer API key(s) for the `bearer-shared` auth mode / conformance harness.
# OPENWOP_API_KEYS=

# --- CORS -------------------------------------------------------------------
# Comma-separated allowed origins. There is NO reflect-any default — set this
# to your frontend origin(s) for a cross-origin (e.g. SSE-direct) deploy.
# OPENWOP_CORS_ORIGINS=https://app.example.com

# --- OIDC (optional, for federated identity) --------------------------------
# ANY OIDC issuer works. The reference frontend ships a Firebase Auth widget;
# swap providers by pointing these at your issuer's discovery values:
#   Firebase: OPENWOP_OIDC_ISSUER=https://securetoken.google.com/<project>
#             OPENWOP_OIDC_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
#   Cognito:  OPENWOP_OIDC_ISSUER=https://cognito-idp.<region>.amazonaws.com/<pool>
#   Entra:    OPENWOP_OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OPENWOP_OIDC_ISSUER=
# OPENWOP_OIDC_AUDIENCE=
# OPENWOP_OIDC_JWKS_URL=

# --- Enterprise SSO: SAML 2.0 (Okta / Azure AD / Ping…) ----------------------
# OFF until all four vars below are set. When set, the host advertises
# `openwop-auth-saml` in /.well-known/openwop, a "Sign in with SSO" button appears,
# and SAML becomes a real login (the ACS provisions a durable `saml:<NameID>` User
# + issues a session). Validation uses @node-saml/node-saml (real XML-DSig).
#
# To enable Okta SSO for a company (two sides — IdP + this host):
#   1. In Okta: create a "SAML 2.0" app.
#      - Single sign-on URL (ACS): https://<your-host>/api/v1/host/openwop-app/auth/saml/sso/acs
#      - Audience URI (SP Entity ID): pick a stable value, e.g. https://<your-host>/saml
#        (use the SAME value as OPENWOP_SAML_SP_ENTITY_ID below)
#      - Name ID format: EmailAddress (recommended); add a `groups` attribute if you
#        want IdP groups captured (group→role mapping is host-side, ADR 0006).
#      - (Optional) import this host's SP metadata instead of typing the above:
#        https://<your-host>/api/v1/host/openwop-app/auth/saml/sso/metadata
#   2. From Okta's app "Sign On" tab, copy the Identity Provider Single Sign-On URL
#      and the Signing Certificate (X.509). Set them here:
# OPENWOP_SAML_IDP_SSO_URL=https://<your-org>.okta.com/app/<app-id>/sso/saml
# OPENWOP_SAML_IDP_CERT=<the X.509 signing cert — full PEM, or one-line base64 body>
# OPENWOP_SAML_SP_ENTITY_ID=https://<your-host>/saml
# OPENWOP_SAML_ACS_URL=https://<your-host>/api/v1/host/openwop-app/auth/saml/sso/acs
# OPENWOP_SAML_TENANT=<tenant SAML users land in; default `default`>

# --- Enterprise provisioning: SCIM 2.0 (Okta / Azure AD lifecycle) -----------
# OFF until OPENWOP_SCIM_BEARER is set. When set, the host advertises
# `openwop-auth-scim` and exposes bearer-authed SCIM 2.0 endpoints the IdP's
# provisioning client POSTs to — so joiners/movers/leavers are synced
# automatically (deactivation is fail-closed: a disabled user stops resolving).
# This is the COMPANION to SAML SSO: SSO authenticates a login; SCIM provisions
# and de-provisions the account out-of-band.
#
# Endpoints (the IdP base URL is `https://<your-host>/api/scim/v2`):
#   POST   /scim/v2/Users            create/upsert a principal (scim:<userName>)
#   PATCH  /scim/v2/Users/{id}       { active } reactivate / deactivate
#   DELETE /scim/v2/Users/{id}       deactivate (leaver)
#   POST   /scim/v2/Groups           group-membership sync (→ ADR 0006 roles)
#
# To enable Okta SCIM provisioning:
#   1. In Okta, on the SAML app's "Provisioning" tab, enable API integration:
#      - SCIM Base URL: https://<your-host>/api/scim/v2
#      - Authentication: HTTP Header → Bearer <the value of OPENWOP_SCIM_BEARER>
#      - Supported actions: Create / Update / Deactivate Users, Push Groups.
#   2. Generate a strong shared secret and set it here (the IdP presents it on
#      every SCIM request; the host compares it in constant time):
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OPENWOP_SCIM_BEARER=
# Tenant SCIM-provisioned users belong to. Defaults to a DEDICATED `scim`
# namespace (NOT `default`, which holds password/OIDC users) so a SCIM bearer can
# never address accounts it didn't provision. Set it to the SSO tenant
# (OPENWOP_SAML_TENANT) if you want SCIM + SAML users to share one workspace.
# OPENWOP_SCIM_TENANT=scim

# --- BYOK (bring-your-own-key) encryption -----------------------------------
# How signed-in tenants' stored credentials are wrapped at rest. Pick ONE:
#   (a) Ephemeral — never persisted (demo / anon only): OPENWOP_BYOK_EPHEMERAL=true
#   (b) Local AES master key — portable, no cloud KMS. 32 bytes, base64; generate
#       with `openssl rand -base64 32` and store as a platform secret.
#   (c) Managed KMS envelope (production `auth` posture). Set the key handle for
#       your cloud; the matching SDK loads lazily (optionalDependencies):
#         GCP:   OPENWOP_BYOK_KMS_KEY=projects/<p>/locations/<l>/keyRings/<r>/cryptoKeys/<k>
#         AWS:   OPENWOP_BYOK_KMS_KEY=aws-kms:arn:aws:kms:<region>:<acct>:key/<id>
#         Azure: OPENWOP_BYOK_KMS_KEY=azure-keyvault:https://<vault>.vault.azure.net/keys/<key>
# OPENWOP_BYOK_EPHEMERAL=true
# OPENWOP_BYOK_ENCRYPTION_KEY=
# OPENWOP_BYOK_KMS_KEY=

# --- Durable host surfaces (kv/table/cache/queue) ---------------------------
# Default 'memory' is process-local and wiped on restart. 'durable' backs the
# surfaces with the relational Storage above (survives restarts, multi-instance).
# OPENWOP_SURFACE_BACKEND=memory
# OPENWOP_SURFACE_KV=durable

# --- Object storage (host.blob) — any S3-compatible store -------------------
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, GCS S3-interop.
# OPENWOP_SURFACE_BLOB=s3
# OPENWOP_BLOB_S3_BUCKET=
# OPENWOP_BLOB_S3_REGION=
# OPENWOP_BLOB_S3_ENDPOINT=               # omit for AWS; set for R2/MinIO/B2
# OPENWOP_BLOB_S3_ACCESS_KEY_ID=
# OPENWOP_BLOB_S3_SECRET_ACCESS_KEY=
# OPENWOP_BLOB_S3_FORCE_PATH_STYLE=true   # MinIO / some non-AWS endpoints

# --- Node packs -------------------------------------------------------------
# Which packs to install on boot (`none` to disable auto-mount).
# OPENWOP_INSTALL_PACKS=
# OPENWOP_LOCAL_PACKS_DIR=
# Dev-mount prefixes (CSV) — which workspace `packs/` subtrees are surfaced.
# REPLACES the default set when present. Default:
#   core.openwop.,vendor.myndhyve.,feature.
# `feature.*` lets a separately-distributed feature package's packs dev-mount
# through the same pipeline (ADR 0001 §2.3). Widen for your own vendor prefix.
# OPENWOP_LOCAL_PACK_PREFIXES=core.openwop.,vendor.myndhyve.,feature.

# --- Feature toggles (ADR 0001 §3) ------------------------------------------
# Who may administer feature toggles via /v1/host/openwop-app/feature-toggles/admin.
# CSV of tenant ids. The gate fails CLOSED — unset ⇒ only the wildcard bearer
# (OPENWOP_API_KEY) can administer.
# OPENWOP_SUPERADMIN_TENANTS=
# EXPLICIT local-dev opt-in: treat ANY authenticated caller as a toggle
# superadmin so the admin screen works without an allowlist. NEVER set in a
# shared/production deploy.
# OPENWOP_FEATURE_TOGGLES_DEV_OPEN=true
# Workflow a CRM contact triage runs (default openwop-app.uppercase).
# OPENWOP_CRM_TRIAGE_WORKFLOW_ID=

# --- Demo / showcase posture (ADR 0015) -------------------------------------
# Demo-deployment master switch. OFF (the default) = production-grade clean:
# NO automatic seeding, NO synthetic `__showcase__` fallback — a fresh /
# white-label install boots empty and every surface reads only the tenant's
# own real data. Set `true` ONLY for the public showcase (app.openwop.dev),
# which boot-seeds the read-only showcase tenant and lets dashboards fall back
# to it (that data is BADGED illustrative in the UI). White-label adopters:
# LEAVE THIS FALSE (or unset).
OPENWOP_DEMO_MODE=false
# Whether explicit, user-triggered seeding (the /example-data dashboard + "Load
# example data" actions) is available at all. Independent of OPENWOP_DEMO_MODE.
# Set `false` to remove the capability entirely from a hardened deploy.
# OPENWOP_DEMO_SEED_ENABLED=true

# --- AI providers (only if you use AI nodes) --------------------------------
# OPENWOP_DEFAULT_AI_PROVIDER=
# OPENWOP_DEFAULT_AI_MODEL=

# --- Observability ----------------------------------------------------------
# Set to `false` to silence the console OTel tracer. (default: on)
# OPENWOP_OTEL_CONSOLE=false
# OTEL_EXPORTER_OTLP_ENDPOINT=
