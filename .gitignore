# deps / build output
node_modules/
**/node_modules/
dist/
lib/
# …but `lib/` is a SOURCE directory under the frontend (byok/lib, …), not build
# output — re-include it so new source files there aren't silently untracked.
!frontend/react/src/**/lib/
!frontend/react/src/**/lib/**
*.tsbuildinfo

# runtime / local
data/
.env
.env.local
.env.*.local
*.log

# test artifacts
coverage/
test-results/
playwright-report/
.playwright/
**/.vite/

# os
.DS_Store

# firebase deploy cache (local)
.firebase/

# white-label distributable (scripts/build-whitelabel-zip.sh)
dist-whitelabel/

# ── secrets / credentials — NEVER commit (this repo is public) ──
# Private keys, certs, key material
*.pem
*.key
*.p12
*.pfx
id_rsa*
# GCP / Firebase / cloud service-account keys + ADC
*service-account*.json
*serviceaccount*.json
*-credentials.json
application_default_credentials.json
gcloud-*.json
gha-creds-*.json
# npm auth
.npmrc
# terraform state (may embed secrets)
*.tfstate
*.tfstate.*
*.tfvars
# any .env variant EXCEPT the intentionally-tracked public build config + examples
.env.*
!.env.production
!.env.production.example
!.env.example
!.env*.example

# Claude Code personal/local settings (never commit)
.claude/settings.local.json

# browser tool (tools/browser) runtime artifacts
.browser-state.json
.browser-server.log
/node_modules/

# ADR 0146 Phase 4a — vendored CPython-WASI runtime (synced via scripts/sync-pythonwasm.sh, never committed)
backend/typescript/vendor/*.wasm
