# ─────────────────────────────────────────────────────────────────────────────
# White-label production-build env — TEMPLATE.
#
# Copy to `.env.production` and fill in YOUR values, then `npm run build`
# (Vite auto-loads `.env.production` in production mode and inlines these into
# the bundle; `vite.config.ts` aborts the build if VITE_OPENWOP_BASE_URL is
# unset or still the dev default).
#
# DO NOT ship the upstream's `.env.production` — it points at the steward's
# backend + Firebase project. `scripts/check-branding.sh` fails if any OpenWOP
# default leaks into your build. Every value below is intentionally BLANK or a
# safe relative default so a forgotten field fails loudly instead of silently
# phoning home.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend wiring ──────────────────────────────────────────────────────────
# Same-origin path to YOUR backend. A relative `/api` is correct whenever the
# SPA and backend sit behind one edge/proxy that routes `/api/**` to the
# backend container — true for every deploy pack (compose nginx, Fly proxy,
# CloudFront/ALB behavior, Azure Container Apps ingress, Firebase `/api`
# rewrite, Render/Railway). See deploy/<host>/ for the per-host routing rule.
VITE_OPENWOP_BASE_URL=/api

# SSE must BYPASS any buffering CDN/proxy in front of `/api` (buffered edges
# break long-lived event streams). Point this DIRECTLY at your backend's public
# origin so the stream is unbuffered. Leave BLANK only if your edge already
# streams `/api` without buffering (e.g. the compose nginx pack).
#   GCP:    https://<backend>-<projectnum>.<region>.run.app
#   Fly:    https://<app>.fly.dev
#   AWS:    your ALB/CloudFront streaming origin
#   Azure:  https://<app>.<region>.azurecontainerapps.io
VITE_OPENWOP_SSE_BASE_URL=

# Auth mode: 'cookie' = per-visitor anon sessions (isolated tenants);
#            'bearer' = a shared token (simplest login-free demo).
VITE_OPENWOP_AUTH_MODE=cookie

# ── Sign-in (optional, OIDC) ─────────────────────────────────────────────────
# The reference frontend ships a Firebase Auth sign-in widget; Firebase is the
# reference OIDC provider, not a requirement. Leave BLANK to disable the sign-in
# UI and run anon cookie mode (works on every host). To wire a non-Firebase OIDC
# issuer (Cognito, Entra ID, Auth0, Keycloak, …), set the backend's
# OPENWOP_OIDC_* vars (see deploy/<host>/) and supply your provider's web SDK
# config here. Never inherit the upstream openwop-dev / app.openwop.dev values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# ── Branding (see WHITE-LABEL.md for the full surface list) ──────────────────
# Set these so `check-branding.sh` passes (no OpenWOP defaults left). Drop your
# icon mark + favicon SVGs in `public/` and point at them. Use MARK_SRC for
# the square sidebar/PWA icon; LOCKUP_SRC is optional for full wordmark assets.
VITE_BRAND_PRODUCT_NAME=
VITE_BRAND_MARK_PRE=
VITE_BRAND_MARK_EMPHASIS=
VITE_BRAND_MARK_SUB=
VITE_BRAND_TAGLINE=
VITE_BRAND_ASSISTANT_NAME=
VITE_BRAND_MARK_SRC=
VITE_BRAND_LOCKUP_SRC=
VITE_BRAND_FAVICON_SRC=
VITE_BRAND_DOCUMENT_TITLE=
VITE_BRAND_PRIMARY_DOMAIN=
VITE_BRAND_INSTANCE_NAME=
VITE_BRAND_HOME_URL=
VITE_BRAND_REPO_URL=
# Optional: VITE_BRAND_FONTS_HREF, VITE_BRAND_FOOTER_TEXT,
# VITE_BRAND_THEME_COLOR, VITE_BRAND_DEFAULT_THEME=system|light|dark
#
# Optional app-wide pre-render gate. `password` stores unlock in localStorage;
# `sign-in` requires Firebase Auth to be configured.
# VITE_BRAND_APP_GATE_MODE=none
# VITE_BRAND_APP_GATE_PASSWORD=
