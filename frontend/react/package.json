{
  "name": "@openwop/app-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenWOP application frontend — React SPA consuming @openwop/openwop.",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && node scripts/check-prompt-ref-defaults.mjs && node scripts/check-brand-resolver.mjs && node scripts/check-css-tokens.mjs && node scripts/check-tsx-color-literals.mjs && node scripts/check-spacing-literals.mjs && vite build && node scripts/check-built-css.mjs && node scripts/check-bundle-budget.mjs && node scripts/check-csp-script-hash.mjs",
    "preview": "vite preview",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "typecheck": "tsc --noEmit",
    "check:prompt-defaults": "node scripts/check-prompt-ref-defaults.mjs",
    "check:css-tokens": "node scripts/check-css-tokens.mjs",
    "check:brand-resolver": "node scripts/check-brand-resolver.mjs",
    "check:built-css": "node scripts/check-built-css.mjs",
    "check:tsx-color-literals": "node scripts/check-tsx-color-literals.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "test:e2e": "playwright test",
    "smoke:live": "node scripts/smoke-live.mjs",
    "check:csp-runtime": "node scripts/check-csp-runtime.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@openwop/openwop": "^1.2.0",
    "@xyflow/react": "^12.10.2",
    "firebase": "^12.13.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.6.0",
    "axe-core": "^4.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
